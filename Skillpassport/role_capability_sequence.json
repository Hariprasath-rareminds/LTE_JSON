{
  "table_name": "role_capability_sequence",
  "description": "Ordered learning plan table that maps each role to a domain-specific sequence of capabilities.",
  "primary_key": "id",
  "fields": [
    {
      "name": "id",
      "type": "uuid",
      "required": true,
      "primary_key": true
    },
    {
      "name": "role_id",
      "type": "uuid",
      "required": true,
      "foreign_key": "roles.id"
    },
    {
      "name": "domain_id",
      "type": "uuid",
      "required": true,
      "foreign_key": "domains.id",
      "description": "Context the step runs in."
    },
    {
      "name": "capability_id",
      "type": "uuid",
      "required": true,
      "foreign_key": "capabilities.id"
    },
    {
      "name": "sequence_step",
      "type": "int",
      "required": true,
      "description": "Ordered step number. Example: 1..N."
    },
    {
      "name": "capability_priority",
      "type": "text",
      "required": false,
      "nullable": true,
      "description": "Priority such as Core or Important."
    },
    {
      "name": "required_level",
      "type": "text",
      "required": false,
      "nullable": true,
      "description": "Required level such as L1, L2, or L3."
    },
    {
      "name": "duration_weeks",
      "type": "int",
      "required": false,
      "nullable": true
    },
    {
      "name": "cumulative_weeks",
      "type": "int",
      "required": false,
      "nullable": true
    },
    {
      "name": "evidence_output",
      "type": "text",
      "required": false,
      "nullable": true,
      "description": "Assessment artifact or evidence output."
    },
    {
      "name": "why_here",
      "type": "text",
      "required": false,
      "nullable": true,
      "description": "Sequencing rationale."
    },
    {
      "name": "plan_phase",
      "type": "text",
      "required": false,
      "nullable": true,
      "description": "Plan phase such as Month 1-2, Month 3-4, or Month 5-6."
    }
  ],
  "constraints": [
    {
      "name": "chk_rcs_sequence_step_positive",
      "type": "check",
      "rule": "sequence_step > 0"
    },
    {
      "name": "chk_rcs_duration_weeks_positive",
      "type": "check",
      "rule": "duration_weeks IS NULL OR duration_weeks > 0"
    },
    {
      "name": "chk_rcs_cumulative_weeks_positive",
      "type": "check",
      "rule": "cumulative_weeks IS NULL OR cumulative_weeks > 0"
    },
    {
      "name": "chk_rcs_required_level_allowed",
      "type": "check",
      "rule": "required_level IS NULL OR required_level IN ('L1','L2','L3')"
    },
    {
      "name": "chk_rcs_priority_allowed",
      "type": "check",
      "rule": "capability_priority IS NULL OR capability_priority IN ('Core','Important')"
    }
  ],
  "unique_constraints": [
    {
      "name": "uq_rcs_role_domain_sequence",
      "columns": [
        "role_id",
        "domain_id",
        "sequence_step"
      ]
    },
    {
      "name": "uq_rcs_role_domain_capability",
      "columns": [
        "role_id",
        "domain_id",
        "capability_id"
      ]
    }
  ],
  "indexes": [
    {
      "name": "idx_rcs_role_domain_sequence",
      "columns": [
        "role_id",
        "domain_id",
        "sequence_step"
      ],
      "type": "unique"
    },
    {
      "name": "idx_rcs_role_id",
      "columns": [
        "role_id"
      ]
    },
    {
      "name": "idx_rcs_domain_id",
      "columns": [
        "domain_id"
      ]
    },
    {
      "name": "idx_rcs_capability_id",
      "columns": [
        "capability_id"
      ]
    },
    {
      "name": "idx_rcs_required_level",
      "columns": [
        "required_level"
      ]
    }
  ],
  "relationships": [
    {
      "type": "many_to_one",
      "related_table": "roles",
      "local_key": "role_id",
      "foreign_key": "id"
    },
    {
      "type": "many_to_one",
      "related_table": "domains",
      "local_key": "domain_id",
      "foreign_key": "id"
    },
    {
      "type": "many_to_one",
      "related_table": "capabilities",
      "local_key": "capability_id",
      "foreign_key": "id"
    }
  ],
  "sample_records": [

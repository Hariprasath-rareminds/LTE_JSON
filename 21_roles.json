      "domain_id": "dom-001",
      "name": "Junior Backend Engineer",
      "role_order": 1,
      "industry": "Corporate Functions",
      "description": "Entry-level backend developer assisting in API and service development.",
      "next_role_id": "role-002",
      "is_active": true,

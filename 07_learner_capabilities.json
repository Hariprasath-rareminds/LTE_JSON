
{
  "table_name": "learner_capabilities",
  "description": "Per-learner capability scores, gap analysis, and role readiness data. One row per learner + capability + learning path + role. This is the single source of truth for the gap engine — current level, required level, gap, and recommendation priority all live here.",
  "primary_key": "id",

  "fields": [
    {
      "name": "id",
      "type": "uuid",
      "required": true,
      "primary_key": true,
      "description": "Unique record identifier",
      "example": "lc-001"
    },
    {
      "name": "learner_id",
      "type": "uuid",
      "required": true,
      "foreign_key": "learner_profiles.id",
      "description": "Learner this capability record belongs to",
      "example": "learner-001"
    },
    {
      "name": "capability_id",
      "type": "uuid",
      "required": true,
      "foreign_key": "capabilities.id",
      "description": "Capability associated with this record. This is the core unit used for gap analysis and progression.",
      "example": "cap-001"
    },
    {
      "name": "learning_path_id",
      "type": "uuid",
      "required": true,
      "foreign_key": "learning_paths.id",
      "description": "The learning path this capability record is scoped to.",
      "example": "path-001"
    },
    {
      "name": "role_id",
      "type": "uuid",
      "required": true,
      "foreign_key": "roles.id",
      "description": "The role this capability is being assessed against.",
      "example": "role-001"
    },
    {
      "name": "current_score",
      "type": "integer",
      "required": true,
      "description": "Raw capability score 0–100 derived from evaluation or assessments",
      "example": 20
    },
    {
      "name": "current_level",
      "type": "integer",
      "required": true,
      "enum": [0, 1, 2, 3, 4],
      "description": "Learner's current capability level on the L0–L4 scale",
      "example": 1
    },
    {
      "name": "required_level",
      "type": "integer",
      "required": true,
      "enum": [0, 1, 2, 3, 4],
      "description": "Minimum capability level required by the role",
      "example": 3
    },
    {
      "name": "gap",
      "type": "integer",
      "required": true,
      "description": "Computed gap = required_level - current_level",
      "example": 2
    },
    {
      "name": "has_gap",
      "type": "boolean",
      "required": true,
      "default": false,
      "description": "True if gap > 0",
      "example": true
    },
    {
      "name": "gap_score",
      "type": "integer",
      "required": true,
      "description": "Gap expressed as a 0–100 score for prioritization",
      "example": 60
    },
    {
      "name": "priority_band",
      "type": "varchar",
      "required": false,
      "nullable": true,
      "enum": ["A", "B"],
      "description": "Recommendation priority band",
      "example": "A"
    },
    {
      "name": "why_needed",
      "type": "text",
      "required": false,
      "nullable": true,
      "description": "Why this capability is needed",
      "example": "Monitor production systems and diagnose runtime issues"
    },
    {
      "name": "how_to_build",
      "type": "text",
      "required": false,
      "nullable": true,
      "description": "How the learner should build this capability",
      "example": "Complete observability training with logging and monitoring tools"
    },
    {
      "name": "created_at",
      "type": "timestamp",
      "required": true,
      "description": "Record creation timestamp",
      "example": "2024-01-01T00:00:00Z"
    },
    {
      "name": "updated_at",
      "type": "timestamp",
      "required": true,
      "description": "Last update timestamp",
      "example": "2024-01-01T00:00:00Z"
    }
  ],

  "constraints": [
    {
      "name": "chk_current_level_range",
      "type": "check",
      "rule": "current_level >= 0 AND current_level <= 4"
    },
    {
      "name": "chk_required_level_range",
      "type": "check",
      "rule": "required_level >= 0 AND required_level <= 4"
    },
    {
      "name": "chk_gap_computed",
      "type": "check",
      "rule": "gap = required_level - current_level"
    },
    {
      "name": "chk_has_gap_consistent",
      "type": "check",
      "rule": "(gap > 0 AND has_gap = true) OR (gap <= 0 AND has_gap = false)"
    }
  ],

  "indexes": [
    {
      "name": "idx_learner_capabilities_unique",
      "columns": ["learner_id", "capability_id", "learning_path_id", "role_id"],
      "type": "composite",
      "unique": true
    },
    {
      "name": "idx_learner_capabilities_learner_path_role",
      "columns": ["learner_id", "learning_path_id", "role_id"],
      "type": "composite"
    },
    {
      "name": "idx_learner_capabilities_has_gap",
      "columns": ["learner_id", "has_gap"],
      "type": "composite"
    },
    {
      "name": "idx_learner_capabilities_priority_band",
      "columns": ["learner_id", "priority_band"],
      "type": "composite"
    },
    {
      "name": "idx_learner_capabilities_role_capability",
      "columns": ["role_id", "capability_id"],
      "type": "composite"
    },
    {
      "name": "idx_learner_capabilities_learner_capability",
      "columns": ["learner_id", "capability_id"],
      "type": "composite"
    }
  ],

  "relationships": [
    {
      "type": "many_to_one",
      "related_table": "learner_profiles",
      "local_key": "learner_id",
      "foreign_key": "id"
    },
    {
      "type": "many_to_one",
      "related_table": "capabilities",
      "local_key": "capability_id",
      "foreign_key": "id"
    },
    {
      "type": "many_to_one",
      "related_table": "learning_paths",
      "local_key": "learning_path_id",
      "foreign_key": "id"
    },
    {
      "type": "many_to_one",
      "related_table": "roles",
      "local_key": "role_id",
      "foreign_key": "id"
    },
    {
      "type": "many_to_one",
      "related_table": "role_capability_map",
      "local_key": ["role_id", "capability_id"],
      "foreign_key": ["role_id", "capability_id"]
    }
  ], 

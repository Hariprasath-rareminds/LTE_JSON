{
  "table_name": "courses",
  "description": "Course catalog where each course represents one capability at one specific proficiency level.",
  "primary_key": "course_id",

  "fields": [
    {
      "name": "course_id",
      "type": "uuid",
      "required": true,
      "primary_key": true
    },
    {
      "name": "course_code",
      "type": "varchar",
      "required": true,
      "unique": true
    },
    {
      "name": "role_id",
      "type": "uuid",
      "required": true,
      "foreign_key": "roles.id"
    },
    {
      "name": "capability_id",
      "type": "uuid",
      "required": true,
      "foreign_key": "capabilities_master.id"
    },
    {
      "name": "capability_code",
      "type": "varchar",
      "required": true
    },
    {
      "name": "capability_name",
      "type": "varchar",
      "required": true
    },

    {
      "name": "level_id",
      "type": "uuid",
      "required": true,
      "foreign_key": "level_scale.id",
      "description": "References the level using UUID (normalized FK)"
    },

    {
      "name": "level_no",
      "type": "integer",
      "required": true,
      "enum": [1, 2, 3, 4, 5],
      "description": "Numeric level for ordering and business logic"
    },
    {
      "name": "level_code",
      "type": "varchar",
      "required": true
    },
    {
      "name": "level_label",
      "type": "varchar",
      "required": true
    },
    {
      "name": "title",
      "type": "varchar",
      "required": true
    },
    {
      "name": "description",
      "type": "text",
      "required": true
    },
    {
      "name": "observable_behavior",
      "type": "text",
      "required": true
    },
    {
      "name": "example_outputs",
      "type": "text",
      "required": true
    },
    {
      "name": "domain_id",
      "type": "uuid",
      "required": true,
      "foreign_key": "domains.id"
    },
    {
      "name": "duration_minutes",
      "type": "integer",
      "required": true
    },
    {
      "name": "xp_reward",
      "type": "integer",
      "required": true
    },
    {
      "name": "difficulty_level",
      "type": "varchar",
      "required": true,
      "enum": ["beginner", "foundation", "intermediate", "advanced", "expert"]
    },
    {
      "name": "thumbnail_url",
      "type": "varchar",
      "nullable": false
    },
    {
      "name": "is_active",
      "type": "boolean",
      "default": true
    },
    {
      "name": "is_published",
      "type": "boolean",
      "default": true
    },
    {
      "name": "version_no",
      "type": "integer",
      "default": 1
    },
    {
      "name": "course_status",
      "type": "varchar",
      "enum": ["published", "draft", "archived"]
    },
    {
      "name": "created_at",
      "type": "timestamp",
      "required": true
    },
    {
      "name": "updated_at",
      "type": "timestamp",
      "required": true
    }
  ],

  "constraints": [
    {
      "name": "chk_level_no_range",
      "type": "check",
      "rule": "level_no BETWEEN 1 AND 5"
    }
  ],

  "unique_constraints": [
    {
      "name": "uq_course_capability_level",
      "columns": ["capability_id", "level_no"]
    },
    {
      "name": "uq_course_code",
      "columns": ["course_code"]
    }
  ],

  "indexes": [
    {
      "name": "idx_courses_capability_level",
      "columns": ["capability_id", "level_no"],
      "type": "unique"
    },
    {
      "name": "idx_courses_role_id",
      "columns": ["role_id"]
    },
    {
      "name": "idx_courses_level_id",
      "columns": ["level_id"],
      "description": "Join optimization with level_scale"
    }
  ],

  "relationships": [
    {
      "type": "many_to_one",
      "related_table": "roles",
      "local_key": "role_id",
      "foreign_key": "id"
    },
    {
      "type": "many_to_one",
      "related_table": "capabilities_master",
      "local_key": "capability_id",
      "foreign_key": "id"
    },
    {
      "type": "many_to_one",
      "related_table": "level_scale",
      "local_key": "level_id",
      "foreign_key": "id",
      "description": "Normalized FK to level_scale"
    }
  ],

  "sample_records": [
    {
      "course_id": "crs-ta-l1",
      "course_code": "TA_L1",
      "role_id": "role-hr-intern",
      "capability_id": "cap-uuid-ta",
      "capability_code": "TA",
      "capability_name": "Talent Acquisition",
      "level_id": "lvl-uuid-001",
      "level_no": 1,
      "level_code": "L1",
      "level_label": "Basic awareness",
      "title": "Talent Acquisition – Basic Awareness",
      "description": "Develops foundational awareness of hiring stages.",
      "observable_behavior": "Understands hiring stages and supports sourcing.",
      "example_outputs": "Resume collection, scheduling support.",
      "domain_id": "dom-hr",
      "duration_minutes": 120,
      "xp_reward": 100,
      "difficulty_level": "beginner",
      "is_active": true,
      "is_published": true,
      "version_no": 1,
      "course_status": "published",
      "created_at": "2024-01-01T00:00:00Z",
      "updated_at": "2024-01-01T00:00:00Z"
    }
  ]
}
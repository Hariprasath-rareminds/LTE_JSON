{
  "schemas": [
    {
      "table_name": "domains",
      "description": "Master table for domain categories. Each domain groups roles, capabilities, and learning steps into a business or knowledge context.",
      "primary_key": "id",
      "fields": [
        {
          "name": "id",
          "type": "uuid",
          "required": true,
          "primary_key": true
        },
        {
          "name": "code",
          "type": "text",
          "required": true,
          "unique": true,
          "description": "Domain code. Example range: D01..D07."
        },
        {
          "name": "name",
          "type": "text",
          "required": true
        },
        {
          "name": "description",
          "type": "text",
          "required": false,
          "nullable": true
        }
      ],
      "constraints": [
        {
          "name": "chk_domains_code_not_empty",
          "type": "check",
          "rule": "length(trim(code)) > 0"
        },
        {
          "name": "chk_domains_name_not_empty",
          "type": "check",
          "rule": "length(trim(name)) > 0"
        }
      ],
      "unique_constraints": [
        {
          "name": "uq_domains_code",
          "columns": [
            "code"
          ]
        }
      ],
      "indexes": [
        {
          "name": "idx_domains_code",
          "columns": [
            "code"
          ],
          "type": "unique"
        },
        {
          "name": "idx_domains_name",
          "columns": [
            "name"
          ]
        }
      ],
      "relationships": [],
      "sample_records": [
        {
          "id": "dom-uuid-001",
          "code": "D01",
          "name": "Healthcare Technology",
          "description": "Domain covering healthcare workflows, systems, and digital health operations."
        },
        {
          "id": "dom-uuid-002",
          "code": "D02",
          "name": "Education Technology",
          "description": "Domain covering learning platforms, curriculum systems, and learner operations."
        },
        {
          "id": "dom-uuid-003",
          "code": "D03",
          "name": "Retail Operations",
          "description": "Domain covering store operations, customer service, inventory, and retail workflows."
        },
        {
          "id": "dom-uuid-004",
          "code": "D04",
          "name": "Financial Services",
          "description": "Domain covering banking, payments, compliance, and financial operations."
        }
      ]
    },
    {
      "table_name": "roles",
      "description": "Role master table. Each role defines a specific work profile with RIASEC attributes, work context, work-style demands, and fitment metadata.",
      "primary_key": "id",
      "fields": [
        {
          "name": "id",
          "type": "uuid",
          "required": true,
          "primary_key": true
        },
        {
          "name": "code",
          "type": "text",
          "required": true,
          "unique": true,
          "description": "Specific role code. Example: HTT-ROLE-001..086."
        },
        {
          "name": "name",
          "type": "text",
          "required": true,
          "description": "Specific role name."
        },
        {
          "name": "primary_riasec",
          "type": "text_array",
          "required": false,
          "nullable": true
        },
        {
          "name": "secondary_riasec",
          "type": "text_array",
          "required": false,
          "nullable": true
        },
        {
          "name": "riasec_code_string",
          "type": "text",
          "required": false,
          "nullable": true,
          "description": "Combined RIASEC code string. Example: ESC."
        },
        {
          "name": "riasec_reason",
          "type": "text",
          "required": false,
          "nullable": true
        },
        {
          "name": "work_context_summary",
          "type": "text",
          "required": false,
          "nullable": true,
          "description": "Embedding-ready work context summary."
        },
        {
          "name": "work_style_demands",
          "type": "text",
          "required": false,
          "nullable": true,
          "description": "Prose description of work-style demands."
        },
        {
          "name": "estimated_plan_weeks",
          "type": "int",
          "required": false,
          "nullable": true
        },
        {
          "name": "fitment_category",
          "type": "text_array",
          "required": false,
          "nullable": true
        },
        {
          "name": "fitment_confidence",
          "type": "text_array",
          "required": false,
          "nullable": true
        },
        {
          "name": "is_active",
          "type": "bool",
          "required": true,
          "default": true
        }
      ],
      "constraints": [
        {
          "name": "chk_roles_code_not_empty",
          "type": "check",
          "rule": "length(trim(code)) > 0"
        },
        {
          "name": "chk_roles_name_not_empty",
          "type": "check",
          "rule": "length(trim(name)) > 0"
        },
        {
          "name": "chk_roles_estimated_plan_weeks_positive",
          "type": "check",
          "rule": "estimated_plan_weeks IS NULL OR estimated_plan_weeks > 0"
        }
      ],
      "unique_constraints": [
        {
          "name": "uq_roles_code",
          "columns": [
            "code"
          ]
        }
      ],
      "indexes": [
        {
          "name": "idx_roles_code",
          "columns": [
            "code"
          ],
          "type": "unique"
        },
        {
          "name": "idx_roles_name",
          "columns": [
            "name"
          ]
        },
        {
          "name": "idx_roles_is_active",
          "columns": [
            "is_active"
          ]
        },
        {
          "name": "idx_roles_riasec_code_string",
          "columns": [
            "riasec_code_string"
          ]
        }
      ],
      "relationships": [
        {
          "type": "one_to_many",
          "related_table": "role_domains",
          "local_key": "id",
          "foreign_key": "role_id"
        },
        {
          "type": "one_to_many",
          "related_table": "role_capability_sequence",
          "local_key": "id",
          "foreign_key": "role_id"
        },
        {
          "type": "one_to_many",
          "related_table": "embeddings",
          "local_key": "id",
          "foreign_key": "entity_id",
          "description": "When embeddings.entity_type = 'role', embeddings.entity_id references roles.id."
        }
      ],
      "sample_records": [

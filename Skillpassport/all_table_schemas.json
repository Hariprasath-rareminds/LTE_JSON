    },
    {
      "table_name": "role_domains",
      "description": "Bridge table connecting roles to domains. Each record defines a role + domain context.",
      "primary_key": "id",
      "fields": [
        {
          "name": "id",
          "type": "uuid",
          "required": true,
          "primary_key": true
        },
        {
          "name": "role_id",

{
  "table_name": "modules_content",
  "description": "Content details for each module in the learning paths and tracks and 6e stages of learning",
  "primary_key": "id",
  "fields": [
    {
      "name": "id",
      "type": "uuid",
      "required": true,
      "primary_key": true,
      "description": "Unique module identifier",
      "example": "mod-content-001"
    },
    {
      "name": "module_id",
      "type": "uuid",
      "required": true,
      "foreign_key": "modules.id",
      "description": "Module this content belongs to",
      "example": "mod-001"
    },
    {
      "name": "content_type",
      "type": "varchar",
      "required": true,
      "enum": [
        "pdf",
        "doc",
        "video",
        "image",
        "slide",
        "link",
        "audio",
        "text"
      ],
      "description": "Type of content",
      "example": "video"
    },
    {
      "name": "stage_name",
      "type": "varchar",
      "required": true,
      "enum": [
        "engage",
        "explore",
        "explain",
        "express",
        "empower",
        "evolve"
      ],
      "description": "6E stage this content is associated with",
      "example": "engage"
    },
    {
      "name": "title",
      "type": "varchar",
      "required": true,
      "description": "Title of the content piece",
      "example": "Introduction to Node.js"
    },
    {
      "name": "description",
      "type": "text",
      "required": false,
      "nullable": true,
      "description": "Brief description of the content",
      "example": "This video covers the basics of Node.js, including setup and core concepts."
    },
    {
      "name": "url",
      "type": "varchar",
      "required": true,
      "description": "URL or path to access the content",
      "example": "https://example.com/content/nodejs-intro.mp4"
    },
    {
      "name": "sort_order",
      "type": "integer",
      "required": true,
      "default": 1,
      "description": "Display sequence order within the same module and stage",
      "example": 1
    },
    {
      "name": "duration_seconds",
      "type": "integer",
      "required": false,
      "nullable": true,
      "description": "Duration of the content in seconds (applicable for videos and audio)",
      "example": 900
    },
    {
      "name": "mime_type",
      "type": "varchar",
      "required": false,
      "nullable": true,
      "enum": [
        "application/pdf",
        "application/msword",
        "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
        "application/vnd.ms-excel",
        "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
        "application/vnd.ms-powerpoint",
        "application/vnd.openxmlformats-officedocument.presentationml.presentation",
        "application/zip",
        "application/x-zip-compressed",
        "application/json",
        "application/xml",
        "application/octet-stream",
        "text/plain",
        "text/html",
        "text/csv",
        "text/markdown",
        "video/mp4",
        "video/webm",
        "video/ogg",
        "video/quicktime",
        "audio/mpeg",
        "audio/ogg",
        "audio/wav",
        "audio/webm",
        "image/jpeg",
        "image/png",
        "image/gif",
        "image/webp",
        "image/svg+xml"
      ],
      "description": "MIME type of the content file",
      "example": "video/mp4"
    },
    {
      "name": "file_size_bytes",
      "type": "integer",
      "required": false,
      "nullable": true,
      "description": "Size of the content file in bytes",
      "example": 20971520
    },
    {
      "name": "version",
      "type": "integer",
      "required": true,
      "description": "Version of the content, useful for tracking updates",
      "example": 1
    },
    {
      "name": "status",
      "type": "varchar",
      "required": true,
      "enum": [
        "draft",
        "published",
        "archived"
      ],
      "description": "Current status of the content",
      "example": "draft"
    },
    {
      "name": "metadata_json",
      "type": "json",
      "required": false,
      "nullable": true,
      "description": "optional small flexible metadata field for additional content only if needed, such as transcript availability, content creator info, or other relevant details that don't require a full separate field",
      "example": {
        "transcript_available": true,
        "content_creator": "John Doe",
        "language": "en"
      }
    },
    {
      "name": "created_at",
      "type": "timestamp",
      "required": true,
      "description": "Record creation timestamp",
      "example": "2024-01-01T00:00:00Z"
    },
    {
      "name": "updated_at",
      "type": "timestamp",
      "required": true,
      "description": "Last update timestamp",
      "example": "2024-01-01T00:00:00Z"
    }
  ],
  "indexes": [
    {
      "name": "idx_modules_content_module_id",
      "columns": [
        "module_id"
      ],
      "description": "Get all content items for a specific module"
    },
    {
      "name": "idx_modules_content_stage_name",
      "columns": [
        "stage_name"
      ],
      "description": "Filter content by 6E stage"
    },
    {
      "name": "idx_modules_content_status",
      "columns": [
        "status"
      ],
      "description": "Show only published/draft/archived content"
    },
    {
      "name": "idx_modules_content_content_type",
      "columns": [
        "content_type"
      ],
      "description": "Filter content assets by type (video, pdf, slide, etc.)"
    },
    {
      "name": "idx_modules_content_module_stage_sort",
      "columns": [
        "module_id",
        "stage_name",
        "sort_order"
      ],
      "type": "composite",
      "description": "Fetch module content ordered within each 6E stage"
    }
  ],
  "relationships": [
    {
      "related_table": "modules",
      "type": "many_to_one",
      "foreign_key": "module_id"
    }
  ],

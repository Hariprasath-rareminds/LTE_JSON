{
  "table_name": "learner_module_progress",
  "description": "Module-level progress header per learner per module. Tracks overall module status, 6E stage completion, artifact submission state, and module lock state. One row per learner per module. Modules unlock sequentially — a module is locked until the previous module's final artifact is approved.",
  "primary_key": "id",

  "fields": [
    {
      "name": "id",
      "type": "uuid",
      "required": true,
      "primary_key": true,
      "description": "Unique record identifier",
      "example": "lmp-001"
    },
    {
      "name": "learner_id",
      "type": "uuid",
      "required": true,
      "foreign_key": "learner_profiles.id",
      "description": "Learner this progress record belongs to",
      "example": "learner-001"
    },
    {
      "name": "learning_path_id",
      "type": "uuid",
      "required": true,
      "foreign_key": "learning_paths.id",
      "description": "Learning path context for this progress record",
      "example": "path-001"
    },
    {
      "name": "course_id",
      "type": "uuid",
      "required": true,
      "foreign_key": "courses.course_id",
      "description": "Course this module belongs to",
      "example": "SE-BE-OBS-01"
    },
    {
      "name": "module_id",
      "type": "uuid",
      "required": true,
      "foreign_key": "modules.id",
      "description": "Module being tracked",
      "example": "mod-001"
    },
    {
      "name": "module_status",
      "type": "varchar",
      "required": true,
      "enum": ["not_started", "in_progress", "completed"],
      "default": "not_started",
      "description": "Overall module completion status. not_started = unlocked but learner has not entered. in_progress = learner has opened at least one 6E stage. completed = all 6 stages done and final artifact approved.",
      "example": "in_progress"
    },
    {
      "name": "current_stage",
      "type": "varchar",
      "required": true,
      "enum": ["none", "engage", "explore", "explain", "express", "empower", "evolve"],
      "default": "none",
      "description": "The 6E stage the learner is currently active in. Set to none if module is not_started. Updated each time a stage row is inserted in learner_6e_stage_progress.",
      "example": "explore"
    },
    {
      "name": "stages_completed",
      "type": "integer",
      "required": true,
      "default": 0,
      "description": "Count of 6E stages completed so far (0-6). Incremented each time a stage moves to completed in learner_6e_stage_progress.",
      "example": 1
    },
    {
      "name": "completion_percentage",
      "type": "integer",
      "required": true,
      "default": 0,
      "description": "Module completion percentage 0-100. Derived as (stages_completed / 6) * 100.",
      "example": 17
    },
    {
      "name": "artifact_submitted",
      "type": "boolean",
      "required": true,
      "default": false,
      "description": "Whether the learner has submitted the module final artifact at least once",
      "example": false
    },
    {
      "name": "artifact_approval_status",
      "type": "varchar",
      "required": true,
      "enum": ["not_submitted", "pending", "under_review", "approved", "returned_for_rework", "rejected"],
      "default": "not_submitted",
      "description": "Current status of the final artifact evaluation. Defaults to not_submitted until artifact is first submitted. Set to approved when evaluation flow completes with approval — this is the trigger that unlocks the next module.",
      "example": "under_review"
    },
    {
      "name": "last_activity_at",
      "type": "timestamp",
      "required": true,
      "default": "created_at",
      "description": "Timestamp of most recent learner activity in this module. Defaults to created_at when no activity has occurred yet.",
      "example": "2024-01-21T00:00:00Z"
    },
    {
      "name": "created_at",
      "type": "timestamp",
      "required": true,
      "example": "2024-01-15T00:00:00Z"
    },
    {
      "name": "updated_at",
      "type": "timestamp",
      "required": true,
      "example": "2024-01-21T00:00:00Z"
    }
  ],

  "constraints": [
    {
      "name": "chk_stages_completed_range",
      "type": "check",
      "rule": "stages_completed >= 0 AND stages_completed <= 6",
      "description": "stages_completed must be between 0 and 6"
    },
    {
      "name": "chk_completion_percentage_range",
      "type": "check",
      "rule": "completion_percentage >= 0 AND completion_percentage <= 100",
      "description": "completion_percentage must be 0-100"
    }
  ],

  "indexes": [
    {
      "name": "idx_lmp_learner_id",
      "columns": ["learner_id"]
    },
    {
      "name": "idx_lmp_module_id",
      "columns": ["module_id"]
    },
    {
      "name": "idx_lmp_learning_path_id",
      "columns": ["learning_path_id"]
    },
    {
      "name": "idx_lmp_learner_module",
      "columns": ["learner_id", "module_id"],
      "type": "composite",
      "unique": true,
      "description": "One progress row per learner per module"
    },
    {
      "name": "idx_lmp_course_learner",
      "columns": ["course_id", "learner_id"],
      "type": "composite",
      "description": "Fetch all module progress rows for a learner in a course in order"
    },
    {
      "name": "idx_lmp_artifact_approval",
      "columns": ["artifact_approval_status"],
      "description": "Find modules pending review or recently approved for progression trigger"
    }
  ],

  "relationships": [
    {
      "type": "many_to_one",
      "related_table": "learner_profiles",
      "local_key": "learner_id",
      "foreign_key": "id"
    },
    {
      "type": "many_to_one",
      "related_table": "learning_paths",
      "local_key": "learning_path_id",
      "foreign_key": "id"
    },
    {
      "type": "many_to_one",
      "related_table": "courses",
      "local_key": "course_id",
      "foreign_key": "course_id"
    },
    {
      "type": "many_to_one",
      "related_table": "modules",
      "local_key": "module_id",
      "foreign_key": "id"
    },
    {
      "type": "one_to_many",
      "related_table": "learner_6e_stage_progress",
      "local_key": "id",
      "foreign_key": "learner_module_progress_id",
      "description": "Each module progress row has up to 6 stage rows"
    }
  ],

  "sample_records": [
    {
      "id": "lmp-001",
      "learner_id": "learner-001",
      "learning_path_id": "path-001",
      "course_id": "SE-BE-OBS-01",
      "module_id": "mod-001",
      "module_status": "in_progress",
      "current_stage": "explore",
      "stages_completed": 1,
      "completion_percentage": 17,
      "artifact_submitted": false,
      "artifact_approval_status": "not_submitted",
      "last_activity_at": "2024-01-21T00:00:00Z",
      "created_at": "2024-01-15T00:00:00Z",
      "updated_at": "2024-01-21T00:00:00Z"
    },
    {
      "id": "lmp-002",
      "learner_id": "learner-001",
      "learning_path_id": "path-001",
      "course_id": "SE-BE-OBS-01",
      "module_id": "mod-002",
      "module_status": "not_started",
      "current_stage": "none",
      "stages_completed": 0,
      "completion_percentage": 0,
      "artifact_submitted": false,
      "artifact_approval_status": "not_submitted",
      "last_activity_at": "2024-01-15T00:00:00Z",
      "created_at": "2024-01-15T00:00:00Z",
      "updated_at": "2024-01-15T00:00:00Z"
    }
  ]
}